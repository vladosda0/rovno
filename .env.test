# Vitest / CI only — valid-looking values so @supabase/supabase-js can construct a client.
# Do not use for real Supabase traffic; copy `.env.example` to `.env` or `.env.local` for dev.
VITE_WORKSPACE_SOURCE="local"
VITE_SUPABASE_URL="https://ci-placeholder.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_ci_placeholder_only"
