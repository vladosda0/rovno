# Local env overrides — never tracked. Use .env.example as the template.
# Active `.env` is selected via `cp .env.<target> .env`:
#   .env.cloud     — Cloud Supabase staging (DEFAULT for local dev)
#   .env.selfhost  — self-host prod (emergency debug only)
#   .env.docker    — local Docker stack via `supabase start`
.env*
!.env.example

