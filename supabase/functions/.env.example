# Edge Function secrets (set in Supabase Dashboard or: supabase secrets set --env-file ...)
# Local testing: supabase functions serve --env-file supabase/functions/.env.local

# Qwen via Alibaba Model Studio — region-specific OpenAI-compatible base URL.
# Example Frankfurt (eu-central-1): https://ws-<workspaceId>.eu-central-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=

QWEN_API_KEY=

# Optional global default when the client omits llmProvider: gigachat | qwen
AI_LLM_PROVIDER=gigachat
