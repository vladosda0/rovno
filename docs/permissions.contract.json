{
  "version": 1,
  "meta": {
    "name": "Rovno Permissions Execution Contract",
    "status": "draft",
    "intended_use": [
      "agent_execution",
      "implementation_planning",
      "deviation_audit"
    ],
    "source_of_truth_priority": [
      "backend_truth",
      "permissions.contract.json",
      "Permissions.md"
    ]
  },
  "principles": {
    "backend_truth_wins": true,
    "hidden_means_hidden": true,
    "summary_is_domain_specific": true,
    "no_financial_data_means_no_money_fields": true,
    "roles_are_default_presets_not_immutable": true,
    "no_grant_above_held_authority": true,
    "ai_authority_is_strict_subset_of_user_authority": true,
    "client_facing_values_must_not_be_inferred_from_internal_values": true
  },
  "vocab": {
    "domain_access": [
      "hidden",
      "summary",
      "view",
      "contribute",
      "manage"
    ],
    "financial_visibility": [
      "none",
      "summary",
      "detail"
    ],
    "action_state": [
      "hidden",
      "disabled_visible",
      "enabled"
    ],
    "doc_visibility_class": [
      "shared_project",
      "internal"
    ]
  },
  "ai_enforcement": {
    "inherit_visibility": true,
    "inherit_actions": true,
    "can_reveal_hidden_fields": false,
    "can_summarize_hidden_fields": false,
    "can_execute_hidden_actions": false,
    "can_execute_disabled_visible_actions": false,
    "can_bypass_missing_buttons_or_hidden_tabs": false,
    "confirmation_does_not_grant_permission": true
  },
  "shared_rules": {
    "mixed_project_portfolio": {
      "mode": "evaluate_per_project"
    },
    "documents_media_classification": {
      "model": [
        "shared_project",
        "internal"
      ],
      "upload_selection_allowed_values": [
        "shared_project",
        "internal"
      ],
      "visual_label_required": true,
      "fallback_when_unclassified": "explicit_fallback_required"
    }
  },
  "roles": {
    "owner": {
      "kind": "preset",
      "description": "highest authority preset",
      "can_create_roles": [
        "co_owner",
        "contractor",
        "viewer"
      ],
      "can_promote_roles": [
        "co_owner",
        "contractor",
        "viewer"
      ],
      "forbidden_forever": []
    },
    "co_owner": {
      "kind": "preset",
      "description": "operational second admin preset",
      "can_create_roles": [
        "contractor",
        "viewer"
      ],
      "can_promote_roles": [
        "contractor",
        "viewer"
      ],
      "forbidden_forever": [
        "create_co_owner",
        "promote_to_co_owner",
        "transfer_ownership",
        "grant_above_held_authority"
      ]
    },
    "contractor": {
      "kind": "preset",
      "description": "operational contributor preset",
      "can_create_roles": [],
      "can_promote_roles": [],
      "forbidden_forever": [
        "invite_management",
        "participant_management",
        "permissions_management",
        "grant_above_held_authority"
      ]
    },
    "viewer": {
      "kind": "preset",
      "description": "client-safe read preset",
      "can_create_roles": [],
      "can_promote_roles": [],
      "forbidden_forever": [
        "invite_management",
        "participant_management",
        "permissions_management",
        "grant_above_held_authority"
      ]
    }
  },
