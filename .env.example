# Workspace source: "local" for browser-backed seeded/local state, or "supabase"
# to use the Supabase workspace source when valid env vars and an auth session exist.
VITE_WORKSPACE_SOURCE=local

# Required only when VITE_WORKSPACE_SOURCE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional convenience echo of the Supabase project ref used in tooling/logs.
VITE_SUPABASE_PROJECT_ID=

# Wave 1 live text assistant: `1` or `true` enables project-context + mock assistant (no backend yet).
# When unset, AISidebar keeps heuristic proposal queue + canned replies.
VITE_AI_LIVE_TEXT_ASSISTANT=

# Yandex Metrika counter ID for product analytics, one per environment. When
# empty or unset, Metrika does NOT initialize: no tag.js is loaded and no hits
# or goals are sent. Use a DIFFERENT counter per environment so local and
# staging traffic never lands in the production counter.
#   - prod    — 109644835
#   - staging — request the staging counter ID from Vlad
#   - dev     — request the dev counter ID from Vlad
VITE_METRIKA_COUNTER_ID=

# Sentry DSN for error tracking (errors only — no tracing/replay). When empty
# or unset, Sentry is fully disabled: the SDK chunk is never downloaded and no
# events are sent. Use a DIFFERENT Sentry project (hence DSN) per environment
# so staging errors never land in the prod project:
#   - prod    — DSN of Sentry project `rovno-frontend-prod`
#   - staging — DSN of Sentry project `rovno-frontend-staging`
#   - local   — leave empty (enable temporarily only to debug the integration)
# All outgoing events pass the PII scrubber (docs/observability/sentry-scrubbing.md).
VITE_SENTRY_DSN=

# Environment label shown by EnvBanner. Hides the warning strip when set to
# "production". Values used in this project:
#   - production — Timeweb prod app `rovno`         (banner hidden)
#   - staging    — Timeweb staging app `rovno-staging`
#   - local      — local dev (npm run dev)
# When unset, the app behaves like production (no banner). Set explicitly per env.
VITE_APP_ENV=

# Feature flag for the Settings → Интеграции (Telegram account-linking) tab.
# Default off. The Telegram bot @rovno_ai_bot consumes link codes against ONE
# Supabase project; until a prod bot pointed at api.rovno.ai ships, the linking
# flow is a dead end on prod, so the tab stays hidden. Set "true" only in an env
# whose bot targets that same env's database.
VITE_TELEGRAM_LINKING_ENABLED=
